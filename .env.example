# Google AI Configuration
GOOGLE_API_KEY=
# Embedding model
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# Transcription + metadata model
GEMINI_FLASH_MODEL=gemini-3.1-flash-lite

# Embedding Configuration
# Matryoshka dim: 128 / 256 / 512 / 1024 / 2048 / 3072
EMBEDDING_DIMENSION=1024

# Scene Detection Configuration
# Lower = more scenes detected
SCENE_THRESHOLD=27.0
# Seconds — merges flash cuts
MIN_SCENE_DURATION=2.0
# Seconds — splits long uncut sequences
MAX_SCENE_DURATION=30.0

# Processing Configuration
# Concurrent chunk workers
MAX_PARALLEL_CHUNKS=4
MAX_ATTEMPTS=10

# Search Weights Configuration
# Visual vector weight in auto mode
SEARCH_VIDEO_WEIGHT=0.50
# Transcript vector weight in auto mode
SEARCH_AUDIO_WEIGHT=0.30
# Metadata vector weight in auto mode
SEARCH_META_WEIGHT=0.20

# Storage Directories
LOCAL_STORAGE_BASE_DIRECTORY=
CONTENT_DIRECTORY=content
EMBEDDINGS_DIRECTORY=embeddings
METADATA_DIRECTORY=metadata
DOCUMENTS_DIRECTORY=documents

# S3 Configuration
S3_REGION=
S3_BUCKET=
S3_SOURCE_PREFIX=

# OpenSearch
OPENSEARCH_HOST=
OPENSEARCH_PORT=
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=
OPENSEARCH_VERIFY_CERTS=
